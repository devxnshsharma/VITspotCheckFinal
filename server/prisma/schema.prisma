generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  name               String
  registrationNumber String?
  karma              Int             @default(100)
  trustTier          String          @default("newcomer")
  welcomeShown       Boolean         @default(false)
  joinedAt           DateTime        @default(now())

  bookings           Booking[]
  speedrests         Speedtest[]
  layouts            LayoutDesign[]
  karmaEvents        KarmaEvent[]
  session            UserSession?
}

model Booking {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  roomName  String
  startTime DateTime
  endTime   DateTime
  reason    String
  status    String   @default("confirmed")
  createdAt DateTime @default(now())
}

model Speedtest {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  sector    String
  download  Int
  upload    Int
  latency   Int
  createdAt DateTime @default(now())
}

model LayoutDesign {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  roomName  String
  schemaStr String
  createdAt DateTime @default(now())
}

model KarmaEvent {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  points      Int
  description String
  refId       String?
  createdAt   DateTime @default(now())
}

model UserSession {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id])
  lastBlock      String?
  preferredIsp   String?
  preferredFloor Int?
  lastActive     DateTime @default(now())
}
